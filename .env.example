# Supabase
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=coloque_a_service_role_key
SUPABASE_BUCKET=choque-videos

# Cloudflare Workers AI
CLOUDFLARE_ACCOUNT_ID=seu_account_id
CLOUDFLARE_API_TOKEN=seu_token
CLOUDFLARE_MODEL=@cf/meta/llama-3.1-8b-instruct

# Instagram Graph API
IG_USER_ID=seu_instagram_business_account_id
INSTAGRAM_ACCESS_TOKEN=seu_token_long_lived

# OpenAlex
OPENALEX_MAILTO=seu_email@exemplo.com

# Execução
DRY_RUN=true
PUBLIC_BASE_URL=

# RSS científico ao vivo
PREFER_RSS=true
RSS_MAX_ITEMS_PER_RUN=40

# Google Sheets auxiliar gratuito — publique a aba como CSV
GOOGLE_SHEETS_CSV_URL=

# Controle de volume para proteger conta e free tier. 36 = uma postagem a cada 40 min.
MAX_POSTS_PER_DAY=36
